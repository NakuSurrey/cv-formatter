# dependencies — installed locally via npm install, never pushed
node_modules/

# local documentation — personal notes and references, never pushed
docs/

# environment variables — may contain secrets later
.env
.env.local
.env.production

# build output — generated by "npm run build", not source code
dist/

# OS junk files
.DS_Store
Thumbs.db

# editor config files
.vscode/
.idea/
*.swp
*.swo

# debug logs from npm
npm-debug.log*
